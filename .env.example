# Supabase Configuration
# Obtené estos valores de tu proyecto en https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Google Maps API
# Necesaria para autocompletado de direcciones y validación de zonas
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key

# Mercado Pago Configuration
# Obtené tus credenciales en https://www.mercadopago.com.ar/developers
NEXT_PUBLIC_MP_PUBLIC_KEY=tu-mercadopago-public-key
MP_ACCESS_TOKEN=tu-mercadopago-access-token

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DELIVERY_PHONE=+54911XXXXXXXX

# WhatsApp Notifications (opcional - para envío de notificaciones)
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_PHONE_NUMBER_ID=tu-phone-number-id

# Configuración de Delivery
NEXT_PUBLIC_BASE_DELIVERY_FEE=500
NEXT_PUBLIC_FREE_DELIVERY_MIN=15000
