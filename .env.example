# Supabase Configuration
# Obtener de: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Supabase Service Role Key (solo para API routes del lado del servidor)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-privada

# Mercado Pago Configuration
# Obtener de: https://www.mercadopago.com.ar/developers/panel/credentials
NEXT_PUBLIC_MP_PUBLIC_KEY=tu-public-key-de-mercadopago
MP_ACCESS_TOKEN=tu-access-token-privado-de-mercadopago

# Google Maps API Key (para autocompletado de direcciones)
# Obtener de: https://console.cloud.google.com/google/maps-apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key

# WhatsApp Business API (para notificaciones)
# Puede ser Twilio, MessageBird, etc.
WHATSAPP_API_URL=https://api.whatsapp-provider.com/v1
WHATSAPP_API_TOKEN=tu-whatsapp-api-token
WHATSAPP_PHONE_NUMBER=+5492641234567

# URLs de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Configuración de delivery
# Zona de cobertura San Juan Capital (valores por defecto)
DELIVERY_BASE_FEE=500
DELIVERY_MAX_DISTANCE_KM=15
FREE_DELIVERY_MIN_AMOUNT=8000

# Configuración de la aplicación
APP_NAME="Bebidas San Juan"
APP_DESCRIPTION="Delivery de bebidas 24hs en San Juan"
ADMIN_EMAIL=admin@bebidassanjuan.com
