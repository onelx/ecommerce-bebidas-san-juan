# Supabase Configuration
# Obtené estos valores desde tu proyecto en https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Supabase Service Role Key (SOLO para server-side, NO expongas públicamente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Mercado Pago Configuration
# Obtené tus credenciales en https://www.mercadopago.com.ar/developers
NEXT_PUBLIC_MP_PUBLIC_KEY=tu-mp-public-key
MP_ACCESS_TOKEN=tu-mp-access-token

# URL base de tu aplicación (para webhooks y redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps API Key (para autocompletado de direcciones)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key

# WhatsApp Business API (opcional, para notificaciones)
WHATSAPP_API_TOKEN=tu-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=tu-phone-number-id

# Configuración de Delivery
# Radio de cobertura en km desde el centro de San Juan
DELIVERY_RADIUS_KM=15
# Coordenadas del centro de distribución
DELIVERY_CENTER_LAT=-31.5375
DELIVERY_CENTER_LNG=-68.5364

# Configuración de Pagos
# Monto mínimo de compra
MIN_ORDER_AMOUNT=1000
# Costo base de delivery
BASE_DELIVERY_FEE=500
