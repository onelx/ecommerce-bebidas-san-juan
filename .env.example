# Supabase Configuration
# Obtén estos valores desde tu dashboard de Supabase: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Mercado Pago Configuration
# Obtén tus credenciales desde: https://www.mercadopago.com.ar/developers/panel
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-tu-public-key-aqui
MERCADOPAGO_ACCESS_TOKEN=TEST-tu-access-token-aqui

# Google Maps API
# Activa la API desde: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key

# WhatsApp Business API (opcional - para notificaciones)
# Configura desde: https://business.facebook.com/
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=tu-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=tu-phone-number-id

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Bebidas San Juan

# Delivery Configuration
NEXT_PUBLIC_DEFAULT_DELIVERY_FEE=500
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD=15000
NEXT_PUBLIC_MAX_DELIVERY_DISTANCE_KM=15

# Email Configuration (opcional - para notificaciones por email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password

# Admin Initial Setup
ADMIN_EMAIL=admin@bebidassanjuan.com
ADMIN_PASSWORD=cambiar-en-produccion
