# Supabase Configuration
# Obtené estos valores desde: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica-aqui

# Supabase Service Role Key (SOLO para server-side, nunca expongas en cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta-aqui

# Mercado Pago Configuration
# Obtené tus credenciales desde: https://www.mercadopago.com.ar/developers/panel/credentials
NEXT_PUBLIC_MP_PUBLIC_KEY=tu-public-key-de-mercadopago
MP_ACCESS_TOKEN=tu-access-token-de-mercadopago

# Google Maps API (para autocompletado de direcciones)
# Creá una API key en: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Bebidas San Juan

# WhatsApp Business API (opcional, para notificaciones)
# Usá un servicio como Twilio o WhatsApp Business API
WHATSAPP_API_TOKEN=tu-whatsapp-api-token
WHATSAPP_PHONE_NUMBER=+549xxxxxxxxxx

# Delivery Configuration
DELIVERY_BASE_FEE=500
DELIVERY_PER_KM_FEE=100
MAX_DELIVERY_DISTANCE_KM=15

# Admin Email (para crear primer admin)
ADMIN_EMAIL=admin@bebidassanjuan.com
