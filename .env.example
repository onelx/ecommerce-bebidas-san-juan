# Supabase Configuration
# Obtener desde: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Mercado Pago Configuration
# Obtener desde: https://www.mercadopago.com.ar/developers/panel/credentials
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=tu-public-key-de-mp
MERCADOPAGO_ACCESS_TOKEN=tu-access-token-de-mp

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Bebidas San Juan

# Google Maps API (para autocompletado de direcciones)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key

# WhatsApp Business API (opcional para notificaciones)
WHATSAPP_API_TOKEN=tu-whatsapp-business-token
WHATSAPP_PHONE_NUMBER_ID=tu-phone-number-id

# Delivery Configuration
NEXT_PUBLIC_DELIVERY_BASE_FEE=500
NEXT_PUBLIC_DELIVERY_PER_KM=100
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD=15000

# Admin Configuration
ADMIN_EMAIL=admin@bebidassanjuan.com
